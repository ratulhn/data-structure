#include<bits/stdc++.h>
using namespace std;

const int N = 3e5 + 9;
const int M = 1e9+7;

int binEx(int a, int b) {
    int ans=1;
    while(b>0) {
        if(b&1) ans = (1ll*ans*a)%M;
        b>>=1;
        a = (1ll*a*a)%M;
    }
    return ans;
}

struct DSU {
  vector<int> par, rnk, sz;
  int c;
  DSU(int n) : par(n + 1), rnk(n + 1, 0), sz(n + 1, 1), c(n) {
    for (int i = 1; i <= n; ++i) par[i] = i;
  }
  int find(int i) {
    return (par[i] == i ? i : (par[i] = find(par[i])));
  }
  bool same(int i, int j) {
    return find(i) == find(j);
  }
  int get_size(int i) {
    return sz[find(i)];
  }
  int count() {
    return c;    //connected components
  }
  int merge(int i, int j) {
    if ((i = find(i)) == (j = find(j))) return -1;
    else --c;
    if (rnk[i] > rnk[j]) swap(i, j);
    par[i] = j;
    sz[j] += sz[i];
    if (rnk[i] == rnk[j]) rnk[j]++;
    return j;
  }
};

int32_t main() {

    int n,m,k; cin>>n>>m>>k;
    if(k==1) {
        cout << binEx(m,n) << "\n";
    } else {
        DSU d(n);
        for(int i=1; i+k-1<=n; i++) {
            int l=i,r=i+k-1;
            while(l<r) {
                d.merge(l,r);
                l++,r--;
            }
        }
        cout << binEx(m,d.count()) << "\n";
    }

  return 0;
}
